# Copy this file to .env and fill in your values.
# Do NOT commit .env.

# Google Maps key used by react-native-maps in Android dev/prod builds.
# Enable "Maps SDK for Android" (and iOS if needed) on this key in Google Cloud.
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Optional but recommended: your unique app identifiers for store-ready builds.
EXPO_ANDROID_PACKAGE=com.yourname.proxiguard
EXPO_IOS_BUNDLE_ID=com.yourname.proxiguard

# Optional: only use if LAN mode has host issues.
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.x.x
